---
import { Image } from 'astro:assets';
import {
  kevinGhostbustersImage,
  kevinKidImage,
  kevinProfileImage,
  kevinVlaImage
} from '../assets/images';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Family from '../components/Family.astro';
import CareerTimeline from '../components/CareerTimeline.astro';
import Connect from '../components/Connect.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Software Engineer"
  description="Principal SWE | Austin | Space nerd"
>
  <Hero />

<Section
    id="odyssey"
    title="My Odyssey"
    intro="Greetings, Fellow Explorer! I’m a software engineer and space nerd based in Austin, driven by a curiosity about how things work—from the scale of the universe to the architecture of an application."
  >
    <div class="odyssey-layout">
      <div class="odyssey-media reveal">
        <Image src={kevinProfileImage} alt="Kevin at work" loading="lazy" class="avatar" />
        <Image src={kevinVlaImage} alt="Kevin at the Very Large Array" loading="lazy" />
        <Image src={kevinKidImage} alt="Kevin in a homemade astronaut costume as a child" loading="lazy" />
        <Image src={kevinGhostbustersImage} alt="Kevin and his boys as Ghostbusters" loading="lazy" />
      </div>
      <div class="odyssey-copy reveal">
        <article class="odyssey-card">
          <h3>I am Kevin:</h3>
          <p>
            I’m a father, husband, and engineer who has called Austin home since 2010. 
            Originally from southwest Florida, I enjoy BBQ, good beer, football, and basketball. 
            I’m also a fan of autumn traditions (especially pumpkins) and like 
            collecting vintage tech that holds nostalgic significance or mark meaningful moments in technology history.
          </p>
        </article>
        <article class="odyssey-card">
          <h3>Science, Space, and Building Systems</h3>
          <p>
            My background is in Space Science and Astrophysics from Florida Tech, where I 
            first discovered my love for programming. That curiosity evolved into 
            a career building and leading software projects across a wide range of industries. 
            You can find the details of that journey on <a href="https://www.linkedin.com/in/kevinharder/" target="_blank" rel="noopener">LinkedIn</a>.
          </p>
        </article>
        <article class="odyssey-card">
          <h3>Voyager Mindset</h3>
          <p>
            I’ve always been fascinated by the principles that govern our world. 
            I was born just as the twin <a href="https://science.nasa.gov/mission/voyager/">Voyager spacecraft</a> began their mission, and I’ve followed 
            their progress into interstellar space with great interest. 
            Their journey is a constant reminder to stay curious and keep looking forward.
          </p>
        </article>
        <article class="odyssey-card">
          <h3>Open Web and Technology</h3>
          <p>
            I’ve hosted my own corner of the web at <a href="https://kevinharder.com" rel="self">KevinHarder.com</a> 
            for over 20 years. I'm an advocate for evolving the internet from isolated islands and gated social platforms into a more interconnected, open frontier. I'm having a blast exploring agentic AI; it's enabling me to accomplish many projects I've had on the to-do list for a long time.
          </p>
        </article>
        <article class="odyssey-card">
          <h3>Personal Side Quests</h3>
          <p>
            Beyond my main role, I enjoy contributing to open-source projects and run <a href="https://harder.dev">Harder Labs</a> 
            as a venture labatory for experimental projects. I also enjoy giving back 
            to the local community through <a href="https://austinpuzzles.com" target="_blank">AustinPuzzles.com</a>, 
            a free puzzle exchange.
          </p>
        </article>
      </div>
    </div>
  </Section>

  <Section
    id="connect"
    title="Connect"
    intro="Howdy! Find me on social, or copy my email in one click."
  >
    <Connect />
  </Section>

  <Section
    id="career"
    title="Career Trajectory"
    intro="Timeline entries are collapsed by default; open any role for details and highlights."
  >
    <CareerTimeline />
  </Section>

  <Section
    id="family"
    title="Family"
    intro="My Crew: My wife and six kids are the center of everything; this is the team behind every milestone."
  >
    <Family />
  </Section>

  <Footer slot="after-main" />
</BaseLayout>
