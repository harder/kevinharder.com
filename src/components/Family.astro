---
import { Image } from 'astro:assets';
import { familyMembers } from '../content/family';
---

<div class="family-grid" role="list" aria-label="Family members">
  {
    familyMembers.map((member) => (
      <article class="family-card reveal" role="listitem">
        <div class="family-card-body">
          <h3>{member.name}</h3>
          {member.link ? (
            <a
              href={member.link}
              target="_blank"
              rel="noopener"
              aria-label={`Visit ${member.name}`}
              class="inline-block text-center"
            >
              <Image
                src={member.image}
                alt={member.name}
                loading="lazy"
              />
            </a>
          ) : (
            <Image
              src={member.image}
              alt={member.name}
              loading="lazy"
            />
          )}
          <p>{member.blurb}</p>
          {member.link && (
            <p class="family-link">
              <a href={member.link} target="_blank" rel="noopener">
                Visit site
              </a>
            </p>
          )}
        </div>
      </article>
    ))
  }
</div>
