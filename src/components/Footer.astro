---
import { Image } from 'astro:assets';
import {
  exoplanetGreetingsImage,
  harderDevImage,
  puzzleExchangeImage
} from '../assets/images';
---

<footer>
  <div class="footer-grid">
    <details class="footer-widget reveal">
      <summary>
        <Image src={harderDevImage} alt="Harder.dev" loading="lazy" />
        <div class="footer-summary-copy">
          <h3>Harder.DEV</h3>
          <p>Engineering tomorrow's possibilities today.</p>
          <p class="footer-static-link">
            <a
              href="https://harder.dev"
              target="_blank"
              rel="noopener noreferrer">Visit Harder.dev</a
            >
          </p>
          <span class="footer-expand-hint">Click to expand details</span>
        </div>
      </summary>
      <div class="footer-extra">
        <p>
          Projects and consulting focused on AI, social, technology, and
          practical software development.
        </p>
      </div>
    </details>

    <details class="footer-widget reveal">
      <summary>
        <Image
          src={puzzleExchangeImage}
          alt="Austin Puzzle Exchange"
          loading="lazy"
        />
        <div class="footer-summary-copy">
          <h3>Austin Puzzles</h3>
          <p>Free local puzzle exchange for the Austin community.</p>
          <p class="footer-static-link">
            <a
              href="https://austinpuzzles.com"
              target="_blank"
              rel="noopener noreferrer">Visit AustinPuzzles.com</a
            >
          </p>
          <span class="footer-expand-hint">Click to expand details</span>
        </div>
      </summary>
      <div class="footer-extra">
        <p>
          A community project that helps people share and discover puzzles
          across Austin. Exchange puzzles with your neighbors: easy, free,
          local, fun!
        </p>
      </div>
    </details>

    <article class="poster-credit poster-credit-art reveal">
      <Image
        src={exoplanetGreetingsImage}
        alt="Exoplanet Greetings"
        loading="lazy"
      />
      <p>Always looking for my next adventure</p>
    </article>
  </div>
  <p class="footer-note">
    &copy; {new Date().getFullYear()} Kevin Harder. &nbsp; Space tourism art courtesy
    NASA/JPL-Caltech.
  </p>
</footer>
